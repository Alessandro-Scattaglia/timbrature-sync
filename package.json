{
  "name": "timbrature-sync",
  "version": "1.0.0",
  "description": "Sincronizza automaticamente le timbrature di Infinity Zucchetti con un file Excel locale.",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "login": "tsx src/login.ts",
    "serve": "tsx src/serve.ts",
    "bookmarklet": "tsx src/generateBookmarklet.ts",
    "build": "tsup src/index.ts src/login.ts src/serve.ts src/generateBookmarklet.ts --format esm --clean",
    "start": "node dist/index.mjs",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "@types/express": "^5.0.3",
    "playwright": "^1.61.1",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  }
}
